{
  "name": "@sai/agent-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starter template for Claude-based agent services",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "eval": "node dist/eval/run.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/node": "catalog:"
  }
}
